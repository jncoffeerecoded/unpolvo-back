generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  locale    String
  cities    City[]
  profiles  Profile[]
  createdAt DateTime  @default(now())
}

model City {
  id        String    @id @default(cuid())
  slug      String
  name      String
  countryId String
  country   Country   @relation(fields: [countryId], references: [id])
  profiles  Profile[]
  createdAt DateTime  @default(now())

  @@unique([countryId, slug])
}

model Profile {
  id       String @id @default(cuid())
  slug     String @unique
  title    String
  nickname String
  bio      String

  age    Int
  gender String

  countryId String
  country   Country @relation(fields: [countryId], references: [id])
  cityId    String
  city      City    @relation(fields: [cityId], references: [id])

  bodyType String?

  // Métodos de contacto que el autor decide mostrar en el anuncio.
  contactEmail    String?
  contactPhone    String? // formato internacional, ej. +34600111222
  contactWhatsapp String? // solo dígitos con código de país, ej. 34600111222

  photos Photo[]

  status        String    @default("pending")
  featuredUntil DateTime?

  commentsCount Int @default(0)
  likesCount    Int @default(0)
  ratingSum     Int @default(0)
  ratingCount   Int @default(0)

  isVerified Boolean   @default(false)
  verifiedAt DateTime?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  comments      Comment[]
  ratings       Rating[]
  likes         Like[]
  notifications Notification[]
  reports       Report[]
  conversations Conversation[]

  plans         SubscriptionPlan[]
  premiumMedia  PremiumMedia[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId, cityId, status])
  @@index([status, featuredUntil])
}

// Plan de suscripción de un anuncio: precio + un paquete de contenido premium.
model SubscriptionPlan {
  id          String  @id @default(cuid())
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  currency    String  @default("USD")
  active      Boolean @default(true)
  order       Int     @default(0)

  media         PremiumMedia[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())

  @@index([profileId, active])
}

// Foto o vídeo premium asociado a un plan. La url es una clave PRIVADA del
// bucket (premium/...): solo se sirve por /media/premium/:id con control de acceso.
model PremiumMedia {
  id        String           @id @default(cuid())
  planId    String
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  profileId String // denormalizado para el chequeo de acceso
  profile   Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  url       String
  type      String // "image" | "video"
  order     Int              @default(0)
  createdAt DateTime         @default(now())

  @@index([planId, order])
}

// Suscripción manual (P2P): el suscriptor entra en lista de espera y el
// anunciante aprueba tras recibir los recaudos por el chat.
model Subscription {
  id             String           @id @default(cuid())
  planId         String
  plan           SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  profileId      String
  profile        Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subscriberId   String
  subscriber     User             @relation("SubscriberOf", fields: [subscriberId], references: [id], onDelete: Cascade)
  ownerId        String // anunciante (denormalizado)
  owner          User             @relation("ApproverOf", fields: [ownerId], references: [id], onDelete: Cascade)
  conversationId String? // chat asociado para los recaudos
  status         String           @default("pending") // pending | approved | rejected

  createdAt DateTime  @default(now())
  decidedAt DateTime?

  @@unique([planId, subscriberId])
  @@index([ownerId, status])
  @@index([subscriberId, status])
}

model Photo {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  order     Int     @default(0)
  isPrimary Boolean @default(false)
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String    @id @default(cuid())
  body      String
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime  @default(now())

  @@index([profileId])
  @@index([parentId])
}

model Rating {
  id        String   @id @default(cuid())
  value     Int
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, userId])
}

model Like {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([profileId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type      String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isVerified    Boolean   @default(false)
  profiles      Profile[]
  accounts      Account[]
  sessions      Session[]

  comments           Comment[]
  ratings            Rating[]
  likes              Like[]
  notifications      Notification[] @relation("NotifRecipient")
  actedNotifications Notification[] @relation("NotifActor")

  conversationsAsOwner Conversation[] @relation("ConversationOwner")
  conversationsAsGuest Conversation[] @relation("ConversationGuest")
  sentMessages         Message[]

  subscriptions Subscription[] @relation("SubscriberOf")
  approvals     Subscription[] @relation("ApproverOf")

  createdAt DateTime @default(now())
}

// Conversación privada entre el visitante (guest) que inicia el contacto y el
// autor (owner) de un anuncio. Una por (perfil, visitante).
model Conversation {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  guestId String
  guest   User   @relation("ConversationGuest", fields: [guestId], references: [id], onDelete: Cascade)

  // pending  → el autor aún no ha respondido; el visitante solo puede 1 mensaje.
  // accepted → el autor respondió; ambos chatean sin límite.
  status String @default("pending")

  messages      Message[]
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@unique([profileId, guestId])
  @@index([ownerId, lastMessageAt])
  @@index([guestId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  attachments MessageAttachment[]

  @@index([conversationId, createdAt])
}

// Adjunto de un mensaje (capturas de recaudos). Clave privada (chat/...),
// servida solo por /media/chat/:id a los participantes de la conversación.
model MessageAttachment {
  id        String  @id @default(cuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  type      String  @default("image")

  @@index([messageId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Report {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reason    String
  details   String?
  createdAt DateTime @default(now())
}
